{
  "name": "livelayer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0",
    "lan:relay": "node scripts/livelayer-lan-relay.mjs",
    "check:output-isolation": "node scripts/check-output-isolation.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "verify": "npm run check:output-isolation && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.2",
    "zod": "^4.4.3",
    "zustand": "^4.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.5",
    "typescript": "^5.6.2",
    "vite": "^5.4.1"
  }
}
